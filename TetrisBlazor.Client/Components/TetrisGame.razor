@implements IAsyncDisposable
@inject HttpClient Http
@inject IJSRuntime JS

<div class="tetris-wrapper">
    <div class="game-area">
        <GameBoard Board="@_state.Board"
                   CurrentPiece="@_state.CurrentPiece"
                   CurrentX="@_state.CurrentX"
                   CurrentY="@_state.CurrentY" />
    </div>
    <div class="sidebar">
        <Sidebar ScoreManager="@_state.ScoreManager"
                 NextPiece="@_state.NextPiece"
                 Leaderboard="@_leaderboard" />
    </div>
</div>

<GameOverlay Status="@_state.Status"
             ScoreManager="@_state.ScoreManager"
             Leaderboard="@_leaderboard"
             OnStart="@StartGame"
             OnSubmitScore="@SubmitScore" />
